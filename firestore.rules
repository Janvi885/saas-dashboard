rules_version = '2';

// Firestore Security Rules for saas-dashboard
//
// Auth model:
// - Firebase Auth handles sign-in; custom claims (role: 'admin' | 'viewer') are set
//   server-side via the Express API (adminAuth.setCustomUserClaims).
// - The frontend talks to Firestore only if you add client SDK reads/writes later.
//   Today, product CRUD goes through the backend (Admin SDK bypasses these rules).
//
// These rules still protect direct client access to Firestore (e.g. future features
// or misconfigured clients).

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ─────────────────────────────────────────────────
    // Reusable checks so rules stay readable and consistent.

    // True when the request includes a valid Firebase Auth session.
    function isAuthenticated() {
      return request.auth != null;
    }

    // True when the user's ID token has a custom claim matching the given role.
    // Roles are assigned by POST /api/admin/set-role (not by the client).
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isViewer() {
      return hasRole('viewer');
    }

    // Either role may read shared catalog data (products).
    function isAdminOrViewer() {
      return isAdmin() || isViewer();
    }

    // True when the authenticated user's uid matches the document path userId.
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ── Product field validation ─────────────────────────────────────────
    // Enforces basic shape on create/update from the client.
    // Stricter validation (SKU format, category enum, etc.) lives in the API.

    function isValidProduct() {
      let d = request.resource.data;
      return d.name is string
          && d.name.size() >= 2
          && d.name.size() <= 100
          && d.price is number
          && d.price >= 0
          && d.status in ['active', 'inactive'];
    }

    // ── /users/{userId} ──────────────────────────────────────────────────
    // Profile / role metadata mirrored from Auth custom claims.
    // Written by the backend on registration and set-role; not user-editable.

    match /users/{userId} {
      // Users can read their own document; admins can read any user profile.
      allow read: if isOwner(userId) || isAdmin();

      // Only admins may create or update user documents (role changes are server-side).
      allow write: if isAdmin();
    }

    // ── /products/{productId} ────────────────────────────────────────────
    // Product catalog. Viewers: read-only. Admins: full CRUD with validation.

    match /products/{productId} {
      // Both admin and viewer roles can list and read products.
      allow read: if isAdminOrViewer();

      // Admins only; new documents must pass isValidProduct().
      allow create: if isAdmin() && isValidProduct();

      // Admins only; updates must keep valid product fields.
      allow update: if isAdmin() && isValidProduct();

      // Admins only; viewers cannot delete.
      allow delete: if isAdmin();
    }

    // ── /rate_limits/{userId} ────────────────────────────────────────────
    // AI rate-limit counters — written only by the backend via Admin SDK.
    // Deny all client access so users cannot reset or spoof their limits.

    match /rate_limits/{userId} {
      allow read, write: if false;
    }

    // ── Deny everything else ─────────────────────────────────────────────
    // Explicit default deny: any collection not matched above is blocked.

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
